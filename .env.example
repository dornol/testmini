# =============================================================================
# TestMini Environment Variables
# =============================================================================

# --- Database (required) ---
# PostgreSQL connection URL
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# --- Application (required) ---
# Public origin URL (no trailing slash)
# Development: http://localhost:5173
# Production:  https://your-domain.com
ORIGIN="http://localhost:5173"

# --- Authentication (required) ---
# Secret key for signing session cookies and tokens.
# PRODUCTION: Generate a strong random secret (minimum 32 characters):
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""

# --- Initial Admin Account (optional) ---
# Override the default admin credentials created on first startup.
# Only used when no users exist in the database.
# Defaults: admin@admin.local / admin1234 / admin
# ADMIN_EMAIL="admin@admin.local"
# ADMIN_PASSWORD="admin1234"
# ADMIN_NAME="admin"

# --- Database Connection Pool (optional) ---
# DB_POOL_MAX="20"         # Max connections (default: 20 prod, 10 dev)
# DB_IDLE_TIMEOUT="30"     # Idle connection timeout in seconds (default: 30)
# DB_CONNECT_TIMEOUT="10"  # Connection timeout in seconds (default: 10)

# --- S3/MinIO Object Storage (optional) ---
# Set S3_BUCKET and S3_ENDPOINT to use S3-compatible storage for file uploads.
# Without these, files are stored on the local filesystem (data/uploads/).
# S3_BUCKET="testmini"
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_ACCESS_KEY_ID="minioadmin"
# S3_SECRET_ACCESS_KEY="minioadmin"

# --- SMTP / Email (optional) ---
# Set SMTP_HOST to enable email notifications (webhook failures, etc.).
# Without these, email features are disabled.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@example.com"
# SMTP_PASS="password"
# SMTP_FROM="noreply@example.com"

# --- Redis (optional) ---
# Set REDIS_URL to enable Redis-backed features (SSE pub/sub, soft locks, rate limiting).
# Without Redis, all features use in-memory fallbacks (suitable for single-server deployments).
# REDIS_URL="redis://localhost:6379"

# =============================================================================
# Production (compose.prod.yaml)
# =============================================================================
# These variables are used by compose.prod.yaml. Not needed for local development.
# DATABASE_URL and REDIS_URL are assembled automatically from the values below.
# To use an external DB/Redis, set DATABASE_URL or REDIS_URL directly instead.

# --- Required ---
# ORIGIN="https://your-domain.com"
# BETTER_AUTH_SECRET=""              # openssl rand -base64 32
# POSTGRES_PASSWORD=""               # openssl rand -base64 24
# REDIS_PASSWORD=""                  # openssl rand -base64 24

# --- Initial Admin Account (optional) ---
# ADMIN_EMAIL="admin@yourcompany.com"
# ADMIN_PASSWORD=""                  # openssl rand -base64 16
# ADMIN_NAME="Admin"

# --- External Database / Redis (optional) ---
# Set these to use an external managed service instead of the Compose containers.
# DATABASE_URL="postgres://user:password@your-db-host:5432/testmini"
# REDIS_URL="redis://:password@your-redis-host:6379"

# --- App container ---
# APP_PORT="3000"
# APP_IMAGE="ghcr.io/dornol/testmini:latest"

# --- Resource limits ---
# APP_MEMORY_LIMIT="512M"
# DB_MEMORY_LIMIT="1G"

# --- Backup ---
# BACKUP_SCHEDULE="0 2 * * *"
# BACKUP_RETAIN="30"
# POSTGRES_HOST="db"                 # Change if backing up an external database
