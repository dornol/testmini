# =============================================================================
# TestMini Environment Variables
# =============================================================================

# --- Database (required) ---
# PostgreSQL connection URL
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

# --- Application (required) ---
# Public origin URL (no trailing slash)
# Development: http://localhost:5173
# Production:  https://your-domain.com
ORIGIN="http://localhost:5173"

# --- Authentication (required) ---
# Secret key for signing session cookies and tokens.
# PRODUCTION: Generate a strong random secret (minimum 32 characters):
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""

# --- Redis (optional) ---
# Redis connection URL for SSE real-time updates and soft locks.
# If not set, defaults to redis://localhost:6379.
# Features like real-time execution updates will be degraded without Redis.
# REDIS_URL="redis://localhost:6379"
