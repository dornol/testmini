{
	"name": "testmini",
	"private": true,
	"version": "0.0.2",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test --config e2e/playwright.config.ts",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:check": "node --import tsx/esm scripts/check-migrations.ts",
		"db:studio": "drizzle-kit studio",
		"seed:test-data": "node --env-file=.env --import tsx/esm scripts/seed-test-data.ts",
		"bench": "node --env-file=.env --import tsx/esm scripts/benchmark.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes",
		"build:analyze": "ANALYZE=true vite build",
		"lighthouse": "lhci autorun",
		"lint": "eslint src/",
		"format": "prettier --write 'src/**/*.{ts,svelte,js,css,html}'",
		"format:check": "prettier --check 'src/**/*.{ts,svelte,js,css,html}'"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@better-auth/cli": "^1.4.21",
		"@inlang/paraglide-js": "^2.15.0",
		"@internationalized/date": "^3.12.0",
		"@lhci/cli": "^0.15.1",
		"@lucide/svelte": "^0.577.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.5.0",
		"@types/node-cron": "^3.0.11",
		"@types/nodemailer": "^7.0.11",
		"@types/pdfkit": "^0.17.5",
		"@vitest/browser-playwright": "^4.1.0",
		"@vitest/coverage-v8": "^4.1.0",
		"better-auth": "^1.5.5",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"drizzle-kit": "^0.31.8",
		"drizzle-orm": "^0.45.1",
		"husky": "^9.1.7",
		"jsdom": "^28.1.0",
		"lucide-svelte": "^0.577.0",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.58.2",
		"postgres": "^3.4.8",
		"rollup-plugin-visualizer": "^7.0.1",
		"svelte": "^5.53.11",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^8.0.0",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1008.0",
		"@modelcontextprotocol/sdk": "^1.27.1",
		"chart.js": "^4.5.1",
		"ioredis": "^5.10.0",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.2",
		"pdfkit": "^0.17.2",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"svelte-dnd-action": "^0.9.69",
		"sveltekit-superforms": "^2.30.0",
		"zod": "^4.3.6"
	}
}
